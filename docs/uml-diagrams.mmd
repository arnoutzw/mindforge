%% === STATE DIAGRAM ===
stateDiagram-v2
    [*] --> Loading : Page load

    Loading --> Initialized : Scripts loaded

    state Initialized {
        [*] --> LocalStorageLoad
        LocalStorageLoad --> FirestoreLoad : Firestore available
        LocalStorageLoad --> Ready : No Firestore
        FirestoreLoad --> Ready : Data loaded
    }

    Ready --> MapActive : Map selected

    state MapActive {
        [*] --> Idle

        state Idle {
            [*] --> Viewing
            Viewing --> NodeSelected : Click node
            NodeSelected --> Viewing : Click empty space
            NodeSelected --> Editing : Double-click / Edit menu
        }

        Idle --> Dragging : Mousedown on node
        Dragging --> Idle : Mouseup
        Dragging --> OverlapResolving : Drop causes overlap
        OverlapResolving --> Idle : Animation complete

        Idle --> Panning : Space+Drag or MMB
        Panning --> Idle : Release

        Idle --> Connecting : Mousedown on connector
        Connecting --> Idle : Mouseup on target connector
        Connecting --> Idle : Mouseup on empty (cancel)

        Idle --> Editing : Open edit modal
        Editing --> Idle : Save / Cancel modal
    }

    state SyncState {
        [*] --> Disconnected
        Disconnected --> Connected : Firebase init
        Connected --> Listening : onSnapshot active
        Listening --> Saving : Local change
        Saving --> Listening : Save complete
        Listening --> RemoteUpdate : Remote snapshot
        RemoteUpdate --> Listening : State updated
        RemoteUpdate --> DeferredSync : Modal open
        DeferredSync --> Listening : Modal closed
    }

    state ZoomState {
        [*] --> Normal
        Normal --> ZoomedIn : Scroll up / Zoom+
        Normal --> ZoomedOut : Scroll down / Zoom-
        ZoomedIn --> Normal : Reset
        ZoomedOut --> Normal : Reset
        ZoomedIn --> FitToScreen : Fit button
        ZoomedOut --> FitToScreen : Fit button
        Normal --> FitToScreen : Fit button
        FitToScreen --> Normal : Calculated zoom applied
    }
